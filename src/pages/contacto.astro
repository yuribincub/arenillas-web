---
// src/pages/contacto.astro
import Layout from "../layouts/Layout.astro";

// Lee el asunto desde la query string (si viene de otro CTA)
const asunto = Astro.url.searchParams.get("asunto") || "";
const asuntoLabel: Record<string, string> = {
    "ruta-espliego": "Ruta del Espliego",
    destilacion: "Visita destilación",
    "boina-fest": "Boina Fest — Información",
    "boina-fest-programa": "Boina Fest — Programa 2025",
};
const asuntoPreset = asunto ? asuntoLabel[asunto] || "" : "";
---

<Layout
    title="Contacto · Arenillas, Soria"
    description="Contacta con el Ayuntamiento de Arenillas, Soria. C/ Real s/n, 42368 Arenillas. Tel: 975 099 222. ayuntamiento@arenillas.es"
>
    <!-- Header -->
    <section class="section-sm bg-crema border-b border-lavanda-light/30">
        <div class="container-brand max-w-2xl">
            <p class="section-label mb-4 reveal">Escríbenos</p>
            <h1 class="text-heading text-carbon mb-4 reveal reveal-delay-1">
                Contacto
            </h1>
            <p class="text-lead reveal reveal-delay-2">
                Cualquier pregunta, sugerencia o propuesta es bienvenida. En
                Arenillas respondemos a todos los mensajes.
            </p>
        </div>
    </section>

    <section class="section bg-crema" aria-labelledby="contacto-form-heading">
        <div class="container-brand">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
                <!-- Formulario -->
                <div class="lg:col-span-3 reveal">
                    <h2
                        id="contacto-form-heading"
                        class="font-serif font-bold text-2xl text-carbon mb-8"
                    >
                        Envíanos un mensaje
                    </h2>

                    <form
                        id="form-contacto"
                        method="POST"
                        action="/api/contacto"
                        class="space-y-6"
                        novalidate
                    >
                        <!-- Nombre -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="field-group">
                                <label for="nombre" class="field-label"
                                    >Nombre <span
                                        class="text-tierra"
                                        aria-hidden="true">*</span
                                    ></label
                                >
                                <input
                                    type="text"
                                    id="nombre"
                                    name="nombre"
                                    required
                                    autocomplete="given-name"
                                    class="field-input"
                                    placeholder="Tu nombre"
                                />
                            </div>
                            <div class="field-group">
                                <label for="apellidos" class="field-label"
                                    >Apellidos</label
                                >
                                <input
                                    type="text"
                                    id="apellidos"
                                    name="apellidos"
                                    autocomplete="family-name"
                                    class="field-input"
                                    placeholder="Tus apellidos"
                                />
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="field-group">
                            <label for="email" class="field-label"
                                >Email <span
                                    class="text-tierra"
                                    aria-hidden="true">*</span
                                ></label
                            >
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                autocomplete="email"
                                class="field-input"
                                placeholder="tu@email.com"
                            />
                        </div>

                        <!-- Teléfono -->
                        <div class="field-group">
                            <label for="telefono" class="field-label"
                                >Teléfono (opcional)</label
                            >
                            <input
                                type="tel"
                                id="telefono"
                                name="telefono"
                                autocomplete="tel"
                                class="field-input"
                                placeholder="+34 600 000 000"
                            />
                        </div>

                        <!-- Asunto -->
                        <div class="field-group">
                            <label for="asunto" class="field-label"
                                >Asunto <span
                                    class="text-tierra"
                                    aria-hidden="true">*</span
                                ></label
                            >
                            <select
                                id="asunto"
                                name="asunto"
                                required
                                class="field-input"
                            >
                                <option
                                    value=""
                                    disabled
                                    selected={!asuntoPreset}
                                    >Selecciona un asunto...</option
                                >
                                {
                                    [
                                        "Información turística",
                                        "Ruta del Espliego",
                                        "Visita destilación",
                                        "Boina Fest — Información",
                                        "Boina Fest — Programa 2025",
                                        "Prensa y medios",
                                        "Trámites ayuntamiento",
                                        "Otro",
                                    ].map((opt) => (
                                        <option
                                            value={opt}
                                            selected={opt === asuntoPreset}
                                        >
                                            {opt}
                                        </option>
                                    ))
                                }
                            </select>
                        </div>

                        <!-- Mensaje -->
                        <div class="field-group">
                            <label for="mensaje" class="field-label"
                                >Mensaje <span
                                    class="text-tierra"
                                    aria-hidden="true">*</span
                                ></label
                            >
                            <textarea
                                id="mensaje"
                                name="mensaje"
                                required
                                rows="5"
                                class="field-input resize-none"
                                placeholder="Cuéntanos en qué podemos ayudarte..."
                            ></textarea>
                        </div>

                        <!-- Privacidad -->
                        <div class="flex items-start gap-3">
                            <input
                                type="checkbox"
                                id="privacidad"
                                name="privacidad"
                                required
                                class="mt-1 w-4 h-4 rounded border-grisclaro text-lavanda-deep
                       focus:ring-2 focus:ring-lavanda-deep focus:ring-offset-1 shrink-0"
                            />
                            <label
                                for="privacidad"
                                class="font-sans text-sm text-humo leading-relaxed"
                            >
                                He leído y acepto la
                                <a
                                    href="/proteccion-datos"
                                    class="text-lavanda-deep underline underline-offset-2"
                                >
                                    Política de Privacidad
                                </a>
                                del Ayuntamiento de Arenillas. <span
                                    class="text-tierra"
                                    aria-hidden="true">*</span
                                >
                            </label>
                        </div>

                        <!-- Submit -->
                        <div class="pt-2">
                            <button
                                type="submit"
                                id="btn-submit"
                                class="btn-primary w-full sm:w-auto justify-center"
                            >
                                <span id="btn-text">Enviar mensaje</span>
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    aria-hidden="true"
                                    id="btn-arrow"
                                >
                                    <path
                                        d="M3 8h10M9 4l4 4-4 4"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"></path>
                                </svg>
                            </button>
                        </div>

                        <!-- Feedback messages -->
                        <div
                            id="msg-success"
                            class="hidden p-4 bg-musgo/10 border border-musgo/30 rounded-xl"
                        >
                            <p class="font-sans text-sm text-musgo">
                                ✓ Mensaje enviado correctamente. Te
                                contestaremos en breve.
                            </p>
                        </div>
                        <div
                            id="msg-error"
                            class="hidden p-4 bg-tierra/10 border border-tierra/30 rounded-xl"
                        >
                            <p class="font-sans text-sm text-tierra-dark">
                                Ha ocurrido un error. Por favor, escríbenos
                                directamente a
                                <a
                                    href="mailto:ayuntamiento@arenillas.es"
                                    class="underline"
                                    >ayuntamiento@arenillas.es</a
                                >
                            </p>
                        </div>
                    </form>
                </div>

                <!-- Sidebar info -->
                <aside class="lg:col-span-2 space-y-6 reveal reveal-delay-2">
                    <h2 class="font-serif font-bold text-2xl text-carbon">
                        Información de contacto
                    </h2>

                    <!-- Cards de contacto -->
                    {
                        [
                            {
                                icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
                                title: "Dirección",
                                lines: [
                                    "C/ Real, s/n",
                                    "42368 Arenillas (Soria)",
                                    "Castilla y León, España",
                                ],
                            },
                            {
                                icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3-8.59A2 2 0 0 1 3.12 1.5h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>`,
                                title: "Teléfono",
                                lines: [
                                    "975 099 222",
                                    "Lunes a viernes: 9h – 14h",
                                ],
                            },
                            {
                                icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
                                title: "Email",
                                lines: ["ayuntamiento@arenillas.es"],
                            },
                        ].map((card) => (
                            <div class="flex items-start gap-4 p-6 bg-lavanda-pale rounded-2xl">
                                <div class="text-lavanda-deep mt-0.5 shrink-0">
                                    {card.icon}
                                </div>
                                <div>
                                    <h3 class="font-sans font-semibold text-sm tracking-wide text-carbon mb-1">
                                        {card.title}
                                    </h3>
                                    {card.lines.map((line) => (
                                        <p class="font-sans text-sm text-humo">
                                            {line}
                                        </p>
                                    ))}
                                </div>
                            </div>
                        ))
                    }

                    <!-- Sede electrónica -->
                    <div class="p-6 bg-lavanda-deep rounded-2xl text-crema">
                        <h3
                            class="font-sans font-semibold text-sm tracking-wide text-lavanda-light mb-2"
                        >
                            Trámites online
                        </h3>
                        <p class="font-sans text-sm text-crema/70 mb-4">
                            Para trámites administrativos, accede a la Sede
                            Electrónica del Ayuntamiento.
                        </p>
                        <a
                            href="https://arenillas.sedelectronica.es"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="btn-primary bg-crema text-lavanda-deep hover:bg-lavanda-light text-sm py-2.5 px-5"
                        >
                            Sede electrónica →
                        </a>
                    </div>

                    <!-- Horario -->
                    <div class="p-6 border border-grisclaro rounded-2xl">
                        <h3
                            class="font-sans font-semibold text-sm tracking-wide text-carbon mb-3"
                        >
                            Horario de atención
                        </h3>
                        <div class="space-y-2 font-sans text-sm text-humo">
                            <div class="flex justify-between">
                                <span>Lunes – Viernes</span>
                                <span class="font-semibold text-carbon"
                                    >09:00 – 14:00</span
                                >
                            </div>
                            <div class="flex justify-between text-grisclaro">
                                <span>Sábado – Domingo</span>
                                <span>Cerrado</span>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>
</Layout>

<script>
    // Form submit con fetch (adaptable a cualquier backend / Netlify Forms / Formspree)
    const form = document.getElementById("form-contacto") as HTMLFormElement;
    const btnSubmit = document.getElementById(
        "btn-submit",
    ) as HTMLButtonElement;
    const btnText = document.getElementById("btn-text")!;
    const msgOk = document.getElementById("msg-success")!;
    const msgErr = document.getElementById("msg-error")!;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        btnSubmit.disabled = true;
        btnText.textContent = "Enviando...";

        try {
            // Cambia la URL según tu backend (Netlify Forms, Formspree, API Route, etc.)
            const res = await fetch(form.action, {
                method: "POST",
                body: new FormData(form),
                headers: { Accept: "application/json" },
            });

            if (res.ok) {
                form.reset();
                msgOk.classList.remove("hidden");
                msgErr.classList.add("hidden");
            } else {
                throw new Error("Error en el servidor");
            }
        } catch {
            msgErr.classList.remove("hidden");
            msgOk.classList.add("hidden");
        } finally {
            btnSubmit.disabled = false;
            btnText.textContent = "Enviar mensaje";
        }
    });
</script>

<style>
    .field-label {
        @apply block font-sans text-sm font-medium text-carbon mb-2;
    }
    .field-input {
        @apply w-full px-4 py-3 rounded-xl border border-grisclaro bg-white
           font-sans text-sm text-carbon placeholder:text-grisclaro
           focus:outline-none focus:ring-2 focus:ring-lavanda-deep focus:border-transparent
           transition-all duration-200;
    }
    .field-input:invalid:not(:placeholder-shown) {
        @apply border-tierra/50;
    }
</style>
