---
// src/pages/actualidad.astro
import Layout from "../layouts/Layout.astro";

const noticias = [
    {
        tipo: "evento",
        titulo: "Boina Fest 2025 — Convocatoria abierta",
        extracto:
            "Ya están abiertas las inscripciones para la 8ª edición del festival. Este año se amplía el escenario y se añaden talleres de artesanía local.",
        fecha: "12 mayo 2025",
        href: "/actualidad/boina-fest-2025",
        img: "/images/actualidad-boina.jpg",
    },
    {
        tipo: "bando",
        titulo: "Corte de agua el 18 de mayo",
        extracto:
            "El servicio de aguas realizará trabajos de mantenimiento en la red principal. Se prevé corte entre las 9:00 y las 14:00h.",
        fecha: "10 mayo 2025",
        href: "/actualidad/corte-agua-mayo",
        img: null,
    },
    {
        tipo: "noticia",
        titulo: "Nueva ruta de senderismo señalizada",
        extracto:
            "La Diputación de Soria ha señalizado un nuevo tramo de ruta circular de 8 km que conecta Arenillas con los molinos del término.",
        fecha: "5 mayo 2025",
        href: "/actualidad/nueva-ruta-senderismo",
        img: "/images/actualidad-ruta.jpg",
    },
    {
        tipo: "evento",
        titulo: "Mercado de espliego · Tercer domingo de junio",
        extracto:
            "Productores locales, destilados artesanales, cosmética natural y gastronomía soriana. El mercado de espliego vuelve a la plaza.",
        fecha: "1 mayo 2025",
        href: "/actualidad/mercado-espliego",
        img: "/images/actualidad-mercado.jpg",
    },
    {
        tipo: "aviso",
        titulo: "Subvenciones rehabilitación de fachadas — Plazo abierto",
        extracto:
            "Hasta el 30 de junio. El Ayuntamiento gestiona las solicitudes de la convocatoria de la Junta de Castilla y León.",
        fecha: "28 abril 2025",
        href: "/actualidad/subvenciones-fachadas",
        img: null,
    },
    {
        tipo: "noticia",
        titulo: "Arenillas en la guía de turismo rural de Soria 2025",
        extracto:
            "El pueblo aparece destacado en la nueva edición de la guía de turismo rural de la Diputación de Soria.",
        fecha: "20 abril 2025",
        href: "/actualidad/guia-turismo-2025",
        img: "/images/actualidad-guia.jpg",
    },
    {
        tipo: "bando",
        titulo: "Reunión vecinal — Presupuestos 2025",
        extracto:
            "Se convoca a todos los vecinos a la reunión informativa sobre el presupuesto municipal del ejercicio 2025. Lunes 26 de mayo, 19:00h.",
        fecha: "15 abril 2025",
        href: "/actualidad/reunion-presupuestos",
        img: null,
    },
    {
        tipo: "aviso",
        titulo: "Recogida de podas y restos vegetales — Mayo",
        extracto:
            "Durante el mes de mayo, el camión de recogida de podas pasará cada miércoles entre las 9:00 y las 12:00h.",
        fecha: "10 abril 2025",
        href: "/actualidad/recogida-podas",
        img: null,
    },
];

const tipoConfig: Record<
    string,
    { label: string; dotColor: string; tagClass: string }
> = {
    noticia: {
        label: "Noticia",
        dotColor: "bg-lavanda-deep",
        tagClass: "tag-lavanda",
    },
    evento: { label: "Evento", dotColor: "bg-tierra", tagClass: "tag-tierra" },
    bando: {
        label: "Bando",
        dotColor: "bg-carbon",
        tagClass: "bg-carbon/10 text-carbon",
    },
    aviso: {
        label: "Aviso",
        dotColor: "bg-musgo",
        tagClass: "bg-musgo/10 text-musgo",
    },
};

const tipos = ["Todos", "Noticia", "Evento", "Bando", "Aviso"];
---

<Layout
    title="Actualidad · Arenillas, Soria"
    description="Noticias, eventos, bandos y avisos del pueblo de Arenillas, Soria. La vida actual de la comunidad."
>
    <!-- Header -->
    <section class="section-sm bg-crema border-b border-lavanda-light/20">
        <div class="container-brand">
            <div class="max-w-2xl reveal">
                <p class="section-label mb-3">Vida del pueblo</p>
                <h1 class="text-heading text-carbon mb-4">Actualidad</h1>
                <p class="text-lead">
                    Lo que pasa en Arenillas. Noticias, eventos, bandos y
                    avisos. La web siempre actualizada.
                </p>
            </div>
        </div>
    </section>

    <!-- Filtros pegajosos -->
    <div
        class="sticky top-16 md:top-20 z-30 bg-crema/95 backdrop-blur-md border-b border-grisclaro/40 py-3"
    >
        <div class="container-brand">
            <ul
                class="flex gap-2 overflow-x-auto pb-1 hide-scrollbar"
                role="list"
                id="filtros"
            >
                {
                    tipos.map((tipo, i) => (
                        <li>
                            <button
                                data-tipo={tipo}
                                class:list={[
                                    "filtro-btn whitespace-nowrap px-4 py-2 rounded-full font-sans text-sm font-medium transition-all duration-200",
                                    i === 0
                                        ? "bg-lavanda-deep text-crema"
                                        : "bg-lavanda-pale text-lavanda-deep hover:bg-lavanda-light",
                                ]}
                            >
                                {tipo}
                            </button>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>

    <!-- Listado -->
    <section class="section bg-crema" aria-label="Listado de noticias">
        <div class="container-brand">
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5"
                id="noticias-grid"
            >
                {
                    noticias.map((n, i) => {
                        const cfg = tipoConfig[n.tipo];
                        return (
                            <article
                                class="noticia-item card reveal group focus-within:ring-2 focus-within:ring-lavanda-deep"
                                data-tipo={cfg.label}
                                style={`animation-delay:${i * 0.06}s`}
                            >
                                <a
                                    href={n.href}
                                    class="block h-full focus:outline-none"
                                >
                                    {n.img ? (
                                        <div class="aspect-video overflow-hidden bg-lavanda-pale">
                                            <img
                                                src={n.img}
                                                alt={n.titulo}
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                                loading="lazy"
                                            />
                                        </div>
                                    ) : (
                                        <div
                                            class={`aspect-video flex items-center justify-center
                               ${n.tipo === "bando" ? "bg-carbon" : n.tipo === "aviso" ? "bg-musgo/10" : "bg-lavanda-pale"}`}
                                        >
                                            <span
                                                class={`font-sans text-xs tracking-[0.25em] uppercase font-semibold
                                  ${n.tipo === "bando" ? "text-crema/40" : "text-humo"}`}
                                            >
                                                {cfg.label}
                                            </span>
                                        </div>
                                    )}

                                    <div class="p-6">
                                        <div class="flex items-center gap-3 mb-3">
                                            <span
                                                class:list={[
                                                    "tag",
                                                    cfg.tagClass,
                                                ]}
                                            >
                                                {cfg.label}
                                            </span>
                                            <span class="font-sans text-xs text-grisclaro">
                                                {n.fecha}
                                            </span>
                                        </div>
                                        <h2
                                            class="font-serif font-bold text-base text-carbon mb-2 leading-snug
                             group-hover:text-lavanda-deep transition-colors line-clamp-2"
                                        >
                                            {n.titulo}
                                        </h2>
                                        <p class="font-sans text-sm text-humo leading-relaxed line-clamp-3">
                                            {n.extracto}
                                        </p>
                                        <p
                                            class="mt-4 font-sans text-xs font-semibold text-lavanda-deep
                             flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity"
                                        >
                                            Leer más
                                            <svg
                                                width="12"
                                                height="12"
                                                viewBox="0 0 16 16"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                aria-hidden="true"
                                            >
                                                <path
                                                    d="M3 8h10M9 4l4 4-4 4"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                />
                                            </svg>
                                        </p>
                                    </div>
                                </a>
                            </article>
                        );
                    })
                }
            </div>

            <p
                id="sin-resultados"
                class="hidden text-center font-serif italic text-humo py-20"
            >
                No hay publicaciones en esta categoría.
            </p>
        </div>
    </section>

    <!-- Suscripción a novedades -->
    <section class="section-sm bg-lavanda-pale/60">
        <div class="container-brand max-w-2xl text-center">
            <h2 class="font-serif font-bold text-xl text-carbon mb-3 reveal">
                Recibe las novedades de Arenillas
            </h2>
            <p class="font-sans text-sm text-humo mb-6 reveal reveal-delay-1">
                Escríbenos y te incluimos en la lista de avisos del pueblo. Solo
                lo importante, sin spam.
            </p>
            <a
                href="/contacto?asunto=suscripcion-novedades"
                class="btn-primary reveal reveal-delay-2"
            >
                Apuntarme
            </a>
        </div>
    </section>
</Layout>

<script>
    const botones = document.querySelectorAll<HTMLButtonElement>(".filtro-btn");
    const items = document.querySelectorAll<HTMLElement>(".noticia-item");
    const sinRes = document.getElementById("sin-resultados")!;

    botones.forEach((btn) => {
        btn.addEventListener("click", () => {
            const tipo = btn.dataset.tipo!;
            botones.forEach((b) => {
                b.classList.replace("bg-lavanda-deep", "bg-lavanda-pale");
                b.classList.replace("text-crema", "text-lavanda-deep");
            });
            btn.classList.replace("bg-lavanda-pale", "bg-lavanda-deep");
            btn.classList.replace("text-lavanda-deep", "text-crema");
            let v = 0;
            items.forEach((el) => {
                const show = tipo === "Todos" || el.dataset.tipo === tipo;
                el.style.display = show ? "" : "none";
                if (show) v++;
            });
            sinRes.classList.toggle("hidden", v > 0);
        });
    });
</script>

<style>
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
