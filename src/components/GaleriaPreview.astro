---
// src/components/GaleriaPreview.astro
import { imageLibrary } from "../data/images.js";

// Las fotos reales se añaden en public/images/
const fotos = [
  {
    src: imageLibrary.vistaAereaFeatured.src,
    alt: imageLibrary.vistaAereaFeatured.alt,
    wide: true,
  },
  {
    src: imageLibrary.espliegoFeatured.src,
    alt: imageLibrary.espliegoFeatured.alt,
  },
  {
    src: imageLibrary.iglesiaFeatured.src,
    alt: imageLibrary.iglesiaFeatured.alt,
  },
  {
    src: imageLibrary.senderismoFeatured.src,
    alt: imageLibrary.senderismoFeatured.alt,
  },
  { src: imageLibrary.barFeatured.src, alt: imageLibrary.barFeatured.alt },
];
---

<section class="section-sm bg-crema" aria-labelledby="galeria-heading">
  <div class="container-brand">
    <div class="flex items-end justify-between mb-10 reveal">
      <div>
        <p class="section-label mb-3">Galería</p>
        <h2
          id="galeria-heading"
          class="text-title font-serif font-bold text-carbon"
        >
          Arenillas en imágenes
        </h2>
      </div>
      <a href="/galeria" class="btn-ghost hidden sm:inline-flex">
        Ver galería completa
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M3 8h10M9 4l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <!-- Masonry-style grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
      <!-- Wide hero image — spans 2 cols -->
      <div class="col-span-2 row-span-2 reveal">
        <div
          class="h-full min-h-[280px] md:min-h-[360px] rounded-2xl overflow-hidden bg-lavanda-pale group cursor-pointer"
        >
          <img
            src={fotos[0].src}
            alt={fotos[0].alt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Other images -->
      {
        fotos.slice(1).map((foto, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <div class="aspect-square rounded-2xl overflow-hidden bg-lavanda-pale group cursor-pointer">
              <img
                src={foto.src}
                alt={foto.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
          </div>
        ))
      }
    </div>

    <div class="text-center mt-8 sm:hidden reveal">
      <a href="/galeria" class="btn-outline">Ver galería completa</a>
    </div>
  </div>
</section>
