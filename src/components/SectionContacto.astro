---
// src/components/SectionContacto.astro
---

<section
  class="section bg-lavanda-deep text-crema relative overflow-hidden"
  aria-labelledby="contacto-cta-heading"
>
  <!-- Decorative lavender -->
  <div
    class="absolute right-0 top-0 bottom-0 w-2/5 opacity-10 pointer-events-none"
    aria-hidden="true"
  >
    <svg
      viewBox="0 0 300 600"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full h-full"
    >
      <line x1="150" y1="600" x2="150" y2="30" stroke="white" stroke-width="2"
      ></line>
      {
        [30, 90, 150, 210, 270, 330, 390, 450, 510].map((y) => (
          <>
            <line
              x1="150"
              y1={y}
              x2="90"
              y2={y + 60}
              stroke="white"
              stroke-width="1.5"
            />
            <line
              x1="150"
              y1={y}
              x2="210"
              y2={y + 60}
              stroke="white"
              stroke-width="1.5"
            />
            <circle cx="85" cy={y + 64} r="8" fill="white" />
            <circle cx="215" cy={y + 64} r="8" fill="white" />
          </>
        ))
      }
    </svg>
  </div>

  <div class="container-brand relative z-10">
    <div class="max-w-2xl">
      <p class="section-label text-lavanda-light mb-6 reveal">Escríbenos</p>

      <h2
        id="contacto-cta-heading"
        class="font-serif font-bold text-crema mb-6 reveal reveal-delay-1"
        style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1;"
      >
        ¿Tienes alguna pregunta<br />sobre Arenillas?
      </h2>

      <p
        class="font-sans text-lg text-crema/70 leading-relaxed mb-10 max-w-lg reveal reveal-delay-2"
      >
        Ya sea para planificar tu visita, para informarte sobre el Boina Fest o
        simplemente para conectar con el pueblo, estamos aquí.
      </p>

      <div class="flex flex-wrap gap-4 mb-14 reveal reveal-delay-3">
        <a
          href="/contacto"
          class="btn-primary bg-crema text-lavanda-deep hover:bg-lavanda-light"
        >
          Contactar ahora
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <a
          href="mailto:ayuntamiento@arenillas.es"
          class="btn-outline border-crema/40 text-crema hover:bg-crema/10"
        >
          ayuntamiento@arenillas.es
        </a>
      </div>

      <!-- Info rápida -->
      <div
        class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-10 border-t border-crema/20 reveal reveal-delay-4"
      >
        {
          [
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
              label: "Dirección",
              value: "C/ Real, s/n\n42368 Arenillas (Soria)",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3-8.59A2 2 0 0 1 3.12 1.5h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>`,
              label: "Teléfono",
              value: "975 099 222",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
              label: "Email",
              value: "ayuntamiento@arenillas.es",
            },
          ].map((item) => (
            <div class="flex items-start gap-3">
              <div class="text-lavanda-light mt-0.5" set:html={item.icon} />
              <div>
                <p class="font-sans text-xs tracking-wider uppercase text-lavanda-light mb-1">
                  {item.label}
                </p>
                <p class="font-sans text-sm text-crema/80 whitespace-pre-line">
                  {item.value}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
